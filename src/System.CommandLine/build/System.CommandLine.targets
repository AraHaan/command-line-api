<Project>

  <PropertyGroup>
    <_SystemCommandLineExecutableName Condition="'$(_SystemCommandLineExecutableName)' == ''">$(AssemblyName)</_SystemCommandLineExecutableName>
  </PropertyGroup>

  <PropertyGroup>
    <_SystemCommandLineGeneratedFile>$(IntermediateOutputPath)System.CommandLine.ExecutableName.g.cs</_SystemCommandLineGeneratedFile>
    <_SystemCommandLineExecutableNameInputsFile>$(IntermediateOutputPath)System.CommandLine.ExecutableName.inputs.cache</_SystemCommandLineExecutableNameInputsFile>
  </PropertyGroup>

  <!-- The gating condition is inlined on each target (rather than hoisted into a property) so
       that it is evaluated at target-execution time: a property assignment would expand the
       VersionGreaterThanOrEquals call and TargetFrameworkVersion early, before the SDK has set
       those values. The module initializer is emitted as C# source, so it must only be generated
       for C# consumers - injecting it into a VB or F# compilation would break the build. It is
       only needed for NativeAOT native-library builds (net5.0+), where there is no managed entry
       point and Environment.GetCommandLineArgs() returns an empty array. -->

  <!-- Capture the only value that affects the generated source - the executable name - into a
       cache file, rewritten only when it changes. This file (not MSBuildAllProjects, which is an
       incrementality antipattern) is the input to the code-generation target. This target has no
       Inputs/Outputs, so it runs on every build: it always adds the generated source to the
       compilation and registers the artifacts for 'dotnet clean', even when the generation
       target below is skipped as up-to-date. -->
  <Target Name="_WriteSystemCommandLineExecutableNameInputs"
          Condition="'$(_SystemCommandLineExecutableName)' != '' and '$(Language)' == 'C#' and '$(TargetFrameworkIdentifier)' == '.NETCoreApp' and $([MSBuild]::VersionGreaterThanOrEquals('$(TargetFrameworkVersion)', '5.0')) and '$(NativeLib)' != ''">

    <WriteLinesToFile File="$(_SystemCommandLineExecutableNameInputsFile)"
                     Lines="$(_SystemCommandLineExecutableName)"
                     Overwrite="true"
                     WriteOnlyWhenDifferent="true" />

    <ItemGroup>
      <Compile Include="$(_SystemCommandLineGeneratedFile)" Condition="!@(Compile->AnyHaveMetadataValue('Identity', '$(_SystemCommandLineGeneratedFile)'))" />
      <FileWrites Include="$(_SystemCommandLineExecutableNameInputsFile)" />
      <FileWrites Include="$(_SystemCommandLineGeneratedFile)" />
    </ItemGroup>

  </Target>

  <Target Name="_GenerateSystemCommandLineExecutableName"
          DependsOnTargets="_WriteSystemCommandLineExecutableNameInputs"
          BeforeTargets="CoreCompile"
          Inputs="$(_SystemCommandLineExecutableNameInputsFile)"
          Outputs="$(_SystemCommandLineGeneratedFile)"
          Condition="'$(_SystemCommandLineExecutableName)' != '' and '$(Language)' == 'C#' and '$(TargetFrameworkIdentifier)' == '.NETCoreApp' and $([MSBuild]::VersionGreaterThanOrEquals('$(TargetFrameworkVersion)', '5.0')) and '$(NativeLib)' != ''">

    <PropertyGroup>
      <_SystemCommandLineGeneratedCode><![CDATA[// <auto-generated/>
namespace System.CommandLine.Generated
{
    internal static class ExecutableNameInitializer
    {
        [global::System.Runtime.CompilerServices.ModuleInitializer]
        internal static void Initialize()
        {
            global::System.AppContext.SetData("System.CommandLine.ExecutableName", "$(_SystemCommandLineExecutableName)");
        }
    }
}
]]></_SystemCommandLineGeneratedCode>
    </PropertyGroup>

    <!-- Escape semicolons so WriteLinesToFile does not treat them as MSBuild list
         separators (which would strip them from the generated C# source). -->
    <WriteLinesToFile File="$(_SystemCommandLineGeneratedFile)"
                     Lines="$(_SystemCommandLineGeneratedCode.Replace(';', '%3B'))"
                     Overwrite="true"
                     WriteOnlyWhenDifferent="true" />

  </Target>

</Project>
