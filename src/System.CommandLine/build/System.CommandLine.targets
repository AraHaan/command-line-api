<Project>

  <!-- Surface the executable name to the runtime as a runtimeconfig.json configProperty. The
       SDK writes RuntimeHostConfigurationOption items into runtimeconfig.json, and the NativeAOT
       ILC bakes the same values into the native image, so the value is available via
       AppContext.GetData in both the managed and native-library hosting models.

       RootCommand reads this as a fallback for its executable name when
       Environment.GetCommandLineArgs() returns an empty array - notably when hosted as a
       NativeAOT native library, which has no managed entry point (issue #2812). -->
  <Target Name="_AddSystemCommandLineExecutableName"
          DependsOnTargets="PrepareForBuild"
          BeforeTargets="GenerateBuildRuntimeConfigurationFiles">

    <PropertyGroup>
      <_SystemCommandLineExecutableName Condition="'$(_SystemCommandLineExecutableName)' == ''">$(AssemblyName)</_SystemCommandLineExecutableName>
    </PropertyGroup>

    <ItemGroup Condition="'$(_SystemCommandLineExecutableName)' != ''">
      <RuntimeHostConfigurationOption Include="System.CommandLine.ExecutableName"
                                      Value="$(_SystemCommandLineExecutableName)"
                                      Trim="false" />
    </ItemGroup>

  </Target>

</Project>
